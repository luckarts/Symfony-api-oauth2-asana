{
  "name": "sylius-nuxt-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "analyze": "nuxt analyze",
    "prepare": "husky",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:e2e": "pnpm test:e2e:clean && playwright test",
    "test:e2e:clean": "rm -rf test-results playwright-report blob-report",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "pnpm test:e2e:clean && playwright test --project=smoke-tests",
    "test:e2e:regression": "pnpm test:e2e:clean && playwright test --project=regression-tests",
    "test:e2e:feature": "pnpm test:e2e:clean && playwright test --project=feature-tests",
    "test:e2e:master": "pnpm test:e2e:clean && playwright test --project=smoke-tests --project=regression-tests",
    "test:e2e:pr": "pnpm test:e2e:clean && playwright test --project=smoke-tests --project=feature-tests",
    "test:e2e:tag:smoke": "pnpm test:e2e:clean && playwright test --grep @smoke",
    "test:e2e:tag:critical": "pnpm test:e2e:clean && playwright test --grep @critical",
    "test:e2e:tag:regression": "pnpm test:e2e:clean && playwright test --grep @regression"
  },
  "lint-staged": {
    "*.{js,ts,vue}": ["biome check --write", "biome format --write"]
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.0",
    "@nuxt/ui": "^3.0.0",
    "@pinia/nuxt": "^0.5.1",
    "@vueuse/core": "^14.0.0",
    "lucide-vue-next": "^0.555.0",
    "nuxt": "^3.15.1",
    "pinia": "^2.1.7",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.13",
    "vue-router": "^4.6.3",
    "vue-tsc": "^3.1.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@nuxtjs/i18n": "^9.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.15.6",
    "@vueuse/nuxt": "^12.0.0",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pg": "^8.16.3",
    "playwright": "^1.57.0",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5.7.3"
  },
  "eslintConfig": {
    "settings": {
      "vue": {
        "version": "3.0"
      }
    }
  }
}
