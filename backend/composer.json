{
    "name": "luckarts/symfony-api-oauth2-ddd",
    "description": "API Symfony 7.3 avec architecture DDD/Hexagonal/CQRS et authentification OAuth2",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
     "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-curl": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-yaml": "*",
        "api-platform/core": "^4.1",
        "doctrine/doctrine-bundle": "^2.16.2",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.5.2",
        "godruoyi/php-snowflake": "^2.2.4",
        "league/oauth2-server-bundle": "^1.0",
        "nelmio/api-doc-bundle": "^4.38.2",
        "nelmio/cors-bundle": "^2.5",
        "nyholm/psr7": "^1.8.2",
        "phpdocumentor/reflection-docblock": "^5.6.3",
        "phpstan/phpdoc-parser": "^1.33",
        "ramsey/uuid": "*",
        "symfony/asset": "7.3.*",
        "symfony/console": "7.3.*",
        "symfony/doctrine-messenger": "7.3.*",
        "symfony/dotenv": "7.3.*",
        "symfony/expression-language": "7.3.*",
        "symfony/flex": "^2.8.2",
        "symfony/form": "7.3.*",
        "symfony/framework-bundle": "7.3.*",
        "symfony/http-client": "7.3.*",
        "symfony/intl": "7.3.*",
        "symfony/mailer": "7.3.*",
        "symfony/messenger": "7.3.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/notifier": "7.3.*",
        "symfony/password-hasher": "7.3.*",
        "symfony/polyfill-uuid": "^1.33",
        "symfony/property-access": "7.3.*",
        "symfony/property-info": "7.3.*",
        "symfony/runtime": "7.3.*",
        "symfony/security-bundle": "7.3.*",
        "symfony/serializer": "7.3.*",
        "symfony/string": "7.3.*",
        "symfony/telegram-notifier": "7.3.*",
        "symfony/translation": "7.3.*",
        "symfony/twig-bundle": "7.3.*",
        "symfony/uid": "7.3.*",
        "symfony/validator": "7.3.*",
        "symfony/web-link": "7.3.*",
        "symfony/yaml": "7.3.*",
        "twig/cssinliner-extra": "^3.21",
        "twig/extra-bundle": "^2.15|^3.21",
        "twig/inky-extra": "^3.21",
        "twig/twig": "^2.15|^3.21.1"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpro/grumphp": true
        },
        "bump-after-update": true,
        "platform": {
            "php": "8.3.0"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "serve": "php -S localhost:8000 -t public/",
        "clear_cache": "php bin/console cache:clear",
        "app:stan":["./vendor/bin/phpstan analyse --memory-limit=-1"],
        "app:code-quality": [
            "./vendor/bin/ecs check --fix",
            "bin/console lint:yaml config --parse-tags",
            "bin/console lint:container"
        ],
        "app:migration": [
            "bin/console doctrine:migrations:migrate"
        ],
        "app:tests": [
            "bin/console cache:clear --env=test",
            "bin/console doctrine:database:create --env=test --if-not-exists --no-interaction || true",
            "bin/console doctrine:schema:drop --force --env=test --no-interaction || true",
            "bin/console doctrine:schema:create --env=test --no-interaction",
            "bin/console cache:clear --env=test",
            "bin/phpunit"
        ],
        "app:tests-dev": [
            "bin/console cache:clear --env=test",
            "bin/phpunit --group=prod"
        ],
        "test:unit": "APP_ENV=test bin/phpunit tests/Unit/",
        "test:integration": "APP_ENV=test bin/phpunit tests/Integration/",
        "test:e2e": "APP_ENV=test bin/phpunit tests/E2E/",
       
        
        "test": "bin/phpunit"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.3.*"
        }
    },
    "require-dev": {
        "phpro/grumphp": "^2.19",
        "phpstan/phpstan": "^2.1.22",
        "phpstan/phpstan-doctrine": "^2.0.4",
        "phpstan/phpstan-symfony": "^2.0.7",
        "phpunit/phpunit": "^12.3.6",
        "symfony/browser-kit": "7.3.*",
        "symfony/css-selector": "7.3.*",
        "symfony/maker-bundle": "^1.64",
        "symplify/easy-coding-standard": "^12.5.24"
    }
}
